MCP_NAME="MCP Template Server"
MCP_VERSION="0.1.0"

# Transport
MCP_SERVER_TRANSPORT=streamable-http

# CORS (for local development)
CORS_ALLOW_ORIGINS=["http://localhost:8000", "http://localhost:3030", "http://localhost:6274"]

# ANTHROPIC_API_KEY=""

# OLLAMA_BASE_URL=""

# Optional: enable payload logging for debugging
# LOG_PAYLOADS=True

# --- Authentication (uncomment and configure as needed) ---
# JWKS_URI="https://your-auth-provider/.well-known/jwks.json"
# JWT_ISSUER="https://your-auth-provider"

# --- Rate Limiting (uncomment and configure as needed) ---
# RATE_LIMIT_SCOPE="my_app"

# --- Application-Specific Settings ---
# Add your domain-specific environment variables here.
# Example:
# DATABASE_URL="postgresql://user:password@localhost:5432/mydb"
# EXTERNAL_API_BASE_URL="https://api.example.com"
# API_SECRET_NAME="my-api-secret"
